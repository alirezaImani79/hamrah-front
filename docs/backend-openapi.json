{
    "openapi": "3.0.0",
    "info": {
        "title": "Hamrah API",
        "description": "REST API for the Hamrah application. Every response uses a uniform JSON envelope: `{ success, message, data }` on success and `{ success, message, errors }` on failure.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://hamrah.test",
            "description": "API server"
        }
    ],
    "paths": {
        "/api/v1/auth/otp/request": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Request an OTP code",
                "description": "Generates a one-time code and sends it to the phone number via SMS.",
                "operationId": "requestOtp",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RequestOtpInput"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Code sent",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Too many requests",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/otp/verify": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Verify an OTP code",
                "description": "Verifies the code, creates the user if needed, and returns a bearer token.",
                "operationId": "verifyOtp",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/VerifyOtpInput"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Authenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthTokenResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Invalid or expired code",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get the authenticated user",
                "description": "Get the currently authenticated user.",
                "operationId": "me",
                "responses": {
                    "200": {
                        "description": "Current user",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Log out (revoke current token)",
                "description": "Revoke the access token used for the current request.",
                "operationId": "logout",
                "responses": {
                    "200": {
                        "description": "Logged out",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/newsletter": {
            "get": {
                "tags": [
                    "Newsletter"
                ],
                "summary": "Get the newsletter subscription status",
                "description": "Show the authenticated user's newsletter subscription status.",
                "operationId": "newsletterStatus",
                "responses": {
                    "200": {
                        "description": "Current status",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/newsletter/subscribe": {
            "post": {
                "tags": [
                    "Newsletter"
                ],
                "summary": "Subscribe to the SMS newsletter",
                "description": "Subscribe the authenticated user to the SMS newsletter.",
                "operationId": "subscribeNewsletter",
                "responses": {
                    "200": {
                        "description": "Subscribed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/newsletter/unsubscribe": {
            "post": {
                "tags": [
                    "Newsletter"
                ],
                "summary": "Unsubscribe from the SMS newsletter",
                "description": "Unsubscribe the authenticated user from the SMS newsletter.",
                "operationId": "unsubscribeNewsletter",
                "responses": {
                    "200": {
                        "description": "Unsubscribed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "RequestOtpInput": {
                "required": [
                    "phone_number"
                ],
                "properties": {
                    "phone_number": {
                        "type": "string",
                        "example": "+15551234567"
                    }
                },
                "type": "object"
            },
            "VerifyOtpInput": {
                "required": [
                    "phone_number",
                    "code"
                ],
                "properties": {
                    "phone_number": {
                        "type": "string",
                        "example": "+15551234567"
                    },
                    "code": {
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "User": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "phone_number": {
                        "type": "string",
                        "example": "+15551234567"
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe",
                        "nullable": true
                    },
                    "email": {
                        "type": "string",
                        "example": "jane@example.com",
                        "nullable": true
                    },
                    "phone_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "is_subscribed_to_newsletter": {
                        "type": "boolean",
                        "example": false
                    },
                    "newsletter_subscribed_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "ApiSuccess": {
                "title": "Success envelope",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "OK"
                    },
                    "data": {
                        "type": "object",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ApiError": {
                "title": "Error envelope",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": false
                    },
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "phone_number": [
                                "The phone number field is required."
                            ]
                        },
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "UserResponse": {
                "title": "User envelope",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/User"
                    }
                },
                "type": "object"
            },
            "AuthTokenResponse": {
                "title": "Authentication envelope",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "properties": {
                            "token": {
                                "type": "string",
                                "example": "1|AbCdEf0123456789..."
                            },
                            "token_type": {
                                "type": "string",
                                "example": "Bearer"
                            },
                            "user": {
                                "$ref": "#/components/schemas/User"
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Pass the token returned by /api/v1/auth/otp/verify as: Authorization: Bearer {token}",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Newsletter",
            "description": "Newsletter"
        }
    ]
}